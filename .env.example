# Ecosistema Soberano — Configuración de Ejemplo
# Copiar a .env y reemplazar con tus valores

# ============================================================================
# GITHUB CONFIGURATION
# ============================================================================

# Token de GitHub con permisos en tu repo
# Generar en: https://github.com/settings/tokens
# Permisos requeridos: repo (acceso completo), workflow
GITHUB_TOKEN=ghp_xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# Owner del repositorio (tu usuario)
GITHUB_OWNER=MAXIMILIANOTARANTO

# Nombre del repositorio
GITHUB_REPO=skills-soberanos

# ============================================================================
# LLM CONFIGURATION (OpenRouter - Modelos Gratuitos)
# ============================================================================

# API Key de OpenRouter (opcional - usa modelos gratis)
# Registrarse en: https://openrouter.ai
# Los siguientes modelos son COMPLETAMENTE GRATUITOS:
# - meta-llama/llama-2-70b-chat
# - mistral/mistral-7b-instruct
# - neural-chat-7b-v3
OPENROUTER_API_KEY=sk-or-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# ECOSYSTEM CONFIGURATION
# ============================================================================

# Modo de operación: local | github | hybrid
ECOSYSTEM_MODE=hybrid

# Nivel de logging: debug | info | warning | error
LOG_LEVEL=info

# Habilitar debug mode (verbose output)
DEBUG=false

# ============================================================================
# PULSE CONFIGURATION
# ============================================================================

# Intervalo de pulse en minutos (solo para testing local)
PULSE_INTERVAL_MINUTES=120

# Máxima duración de un pulse en segundos
MAX_PULSE_DURATION_SECONDS=300

# Habilitar auto-commit después de pulse
AUTO_COMMIT=true

# ============================================================================
# MEMORY CONFIGURATION
# ============================================================================

# Ruta base para almacenamiento de memoria
MEMORY_BASE_PATH=memoria

# Mantener memorias por N días (después se archivar)
MEMORY_RETENTION_DAYS=90

# Tamaño máximo de un archivo de memoria (en KB)
MAX_MEMORY_FILE_SIZE_KB=500

# ============================================================================
# COHERENCE CONFIGURATION
# ============================================================================

# Umbral crítico de Q(t)
Q_CRITICAL_THRESHOLD=0.5

# Umbral de warning de Q(t)
Q_WARNING_THRESHOLD=0.65

# Umbral óptimo de Q(t)
Q_OPTIMAL_THRESHOLD=0.8

# Días a considerar para análisis de tendencia
TREND_ANALYSIS_DAYS=7

# ============================================================================
# CRISIS HANDLING
# ============================================================================

# Detectar MACRO crisis si decline diario > este valor
MACRO_CRISIS_THRESHOLD=-0.08

# Detectar SHOCK crisis si caída en una conversación > este valor
SHOCK_CRISIS_THRESHOLD=0.25

# Ventana de análisis para MACRO crisis (días)
MACRO_CRISIS_WINDOW_DAYS=7

# ============================================================================
# SKILLS CONFIGURATION
# ============================================================================

# Skills a cargar en startup (separados por comas)
ACTIVE_SKILLS=coherence-pulse,memory-manager,meta-hilo-grok

# Máximo de skills a ejecutar en un pulse
MAX_SKILLS_PER_PULSE=3

# Threshold mínimo de resonancia para activar skill
MIN_RESONANCE_THRESHOLD=0.45

# ============================================================================
# DASHBOARD CONFIGURATION
# ============================================================================

# Habilitar generación de datos para dashboard
GENERATE_DASHBOARD_DATA=true

# Ruta de salida para datos del dashboard
DASHBOARD_DATA_PATH=ui/data

# Días de histórico a mostrar en dashboard
DASHBOARD_HISTORY_DAYS=30

# ============================================================================
# OPTIONAL: VERCEL/DEPLOYMENT
# ============================================================================

# Habilitar auto-deployment a Vercel (futuro)
VERCEL_ENABLED=false

# Token de Vercel (si está habilitado)
# VERCEL_TOKEN=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# ============================================================================
# OPTIONAL: SENTRY (Error Tracking)
# ============================================================================

# Habilitar Sentry para tracking de errores (futuro)
SENTRY_ENABLED=false

# DSN de Sentry
# SENTRY_DSN=https://xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx@sentry.io/xxxxxxxxx
